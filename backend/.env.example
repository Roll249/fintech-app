# Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://fintech:fintech123@localhost:5432/fintech_db

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Firebase (for push notifications)
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Private Key Here\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@fintechapp.com

# OCR - Tesseract (local)
TESSERACT_LANG=vie+eng
OCR_PROVIDER=tesseract
OCR_FALLBACK_ENABLED=true
OCR_CONFIDENCE_THRESHOLD=60
OCR_AUTO_ACCEPT_THRESHOLD=85

# Google Vision API (optional - for better OCR)
GOOGLE_VISION_ENABLED=false
GOOGLE_PROJECT_ID=your-google-project
GOOGLE_CLIENT_EMAIL=vision-api@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Private Key Here\n-----END PRIVATE KEY-----"
VISION_MAX_RETRIES=2
VISION_TIMEOUT_MS=30000

# Bank Integration
BANK_WEBHOOK_SECRET=your-webhook-secret-for-hmac
BANK_SYNC_INTERVAL_MINUTES=5
BANK_OAUTH_CLIENT_ID=your-bank-oauth-client-id
BANK_OAUTH_CLIENT_SECRET=your-bank-oauth-client-secret

# Chart Generation
CHART_PROVIDER=quickchart
QUICKCHART_API_URL=https://quickchart.io
CHART_CACHE_TTL=3600

# Queue & Scheduler
QUEUE_CONCURRENCY=5
QUEUE_MAX_RETRIES=3
ENABLE_QUEUE_WORKER=true
ENABLE_SCHEDULER=true

# Security
MAX_DEVICES_PER_USER=5
PASSWORD_RESET_EXPIRE_MINUTES=60
WEBHOOK_TIMESTAMP_TOLERANCE=300
